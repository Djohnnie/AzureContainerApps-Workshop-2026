@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div style="min-height: 100vh; background-color: #0d1117; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1rem;">
    @Body
</div>

@code {
    private readonly MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Background = "#0d1117",
            Surface = "#161b22",
            Primary = "#4ade80",
        },
        PaletteDark = new PaletteDark
        {
            Background = "#0d1117",
            Surface = "#161b22",
            Primary = "#4ade80",
        }
    };
}
