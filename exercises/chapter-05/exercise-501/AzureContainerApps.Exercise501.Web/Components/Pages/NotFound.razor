@page "/not-found"
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-4">404</MudText>
    <MudText Typo="Typo.h6" Style="color: #e6edf3;" Class="mb-4">Page Not Found</MudText>
    <MudText Typo="Typo.body1" Style="color: #8b949e;" Class="mb-6">
        The page you are looking for does not exist.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">
        Back to Home
    </MudButton>
</MudContainer>
