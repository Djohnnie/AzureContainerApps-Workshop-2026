<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <PropertyGroup>
    <UseAspire Condition="'$(UseAspire)' == ''">true</UseAspire>
    <DefineConstants Condition="'$(UseAspire)' == 'true'">$(DefineConstants);ASPIRE</DefineConstants>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseAspire)' == 'true'">
    <ProjectReference Include="../AzureContainerApps.Exercise302.ServiceDefaults/AzureContainerApps.Exercise302.ServiceDefaults.csproj" />
  </ItemGroup>

</Project>
